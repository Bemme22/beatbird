# ── Secrets (NEVER commit) ───────────────────────────────────────────────────
/secrets/
*.local.yml
*.secret
wifi.pass
mqtt.pass
# Mapping rules used to anonymise the repo for going public — the LHS
# of each substitution IS the personal data we're scrubbing.
.history-rewrite-replacements.txt

# ── Local profile (generated by `make profile PROFILE=…` if not committed) ──
/profiles/current.yml

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── PlatformIO / ESP32 ───────────────────────────────────────────────────────
firmware/**/.pio/
firmware/**/.pioenvs/
firmware/**/.piolibdeps/
firmware/**/lib_deps_external/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/
.idea/
*.swp
.DS_Store

# ── Claude / local notes ─────────────────────────────────────────────────────
.claude/
NOTES.local.md

# ── Build artefacts ──────────────────────────────────────────────────────────
build/
dist/
*.bak
*.backup
*.corrupted

# TI datasheets — local reference only, not in the public repo (bloat + copyright)
docs/TI/*.pdf
