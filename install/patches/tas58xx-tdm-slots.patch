diff --git a/tas58xx.h b/tas58xx.h
index 414e561..ee64bc3 100644
--- a/tas58xx.h
+++ b/tas58xx.h
@@ -24,6 +24,8 @@
 #define TAS58XX_REG_DEVICE_CTRL_1   0x02
 #define TAS58XX_REG_DEVICE_CTRL_2   0x03
 #define TAS58XX_REG_SDOUT_SEL       0x30
+#define TAS58XX_REG_SAP_CTRL1       0x33
+#define TAS58XX_REG_SAP_CTRL2       0x34
 #define TAS58XX_REG_CLKDET_STATUS   0x39
 #define TAS58XX_REG_UNDOCUMENTED_0  0x46
 #define TAS58XX_REG_VOL_CTRL        0x4c
@@ -89,6 +91,31 @@
 #define TAS58XX_DCTRL1_FSW480KHZ    GENMASK(5,4)
 #define TAS58XX_DCTRL1_FSW576KHZ    BIT(6)
 
+/* TAS58XX_REG_SAP_CTRL1 (0x33) field encodings — Serial Audio Port format.
+ *   D[7]   : data-offset MSB (paired with SAP_CTRL2 D[7:0] for the full offset)
+ *   D[5:4] : data format select (I2S / LJ / RJ / TDM-DSP)
+ *   D[3:2] : set 0b01 if the LRCLK/FS high width in TDM mode is < 8 SCLK cycles
+ *   D[1:0] : word length (16 / 20 / 24 / 32 bit)
+ * Default (chip reset) is I2S, 24-bit.
+ *
+ * CONFIRMED via the datasheet register map — TAS5825M and TAS5805M both
+ * document SAP_CTRL1 identically (TAS5825M 7.6.1.9 / Table 7-16):
+ *   D[5:4] DATA_FORMAT: 00=I2S, 01=TDM/DSP, 10=RTJ, 11=LTJ  ->  TDM = 0b01
+ *   D[3:2] I2S_LRCLK_PULSE = 01 when FS high width < 8 SCLK (Pi dsp_a narrow FS)
+ *   D[1:0] WORD_LENGTH: 11 = 32-bit
+ * Composite = 0x17, valid for both the 5825M (mids/woofer) and 5805M (ribbon).
+ * The 0x34 RX slot offset (32 x slot-index = 0/64/128) was confirmed by
+ * Andriy (Sonocotta): the Pi always pads to 32-bit slots.
+ */
+#define TAS58XX_SAP_FMT_I2S        (0x0 << 4)
+#define TAS58XX_SAP_FMT_TDM        (0x1 << 4)   /* D[5:4]=01 TDM/DSP — datasheet 7.6.1.9 */
+#define TAS58XX_SAP_WLEN_16        0x0
+#define TAS58XX_SAP_WLEN_20        0x1
+#define TAS58XX_SAP_WLEN_24        0x2
+#define TAS58XX_SAP_WLEN_32        0x3
+/* Composite SAP_CTRL1 for a 32-bit TDM frame. D[3:2]=01 = FS high-width <8 SCLK (Pi dsp_a narrow FS, datasheet 9.3.6). D[5:4] format still UNCONFIRMED. */
+#define TAS58XX_SAP_CTRL1_TDM_32   (TAS58XX_SAP_FMT_TDM | (0x1 << 2) | TAS58XX_SAP_WLEN_32)
+
 /* TAS58XX_REG_DEVICE_CTRL_2 register values */
 #define TAS58XX_DCTRL2_MODE_DEEP_SLEEP 0x00
 #define TAS58XX_DCTRL2_MODE_SLEEP      0x01
